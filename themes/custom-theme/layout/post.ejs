<article class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    <div class="post-meta">
      <span class="post-date">{{ page.date.format('YYYY/MM/DD') }}</span>
      {% if page.categories %}
      <span class="post-categories">
        {% for cat in page.categories.toArray() %}
        <a href="{{ url_for(cat.path) }}">{{ cat.name }}</a>{% if not loop.last %}, {% endif %}
        {% endfor %}
      </span>
      {% endif %}
    </div>
  </header>

  <div class="post-content">
    {{ page.content }}
  </div>

  {% if page.toc %}
  <div class="toc-container">
    <div id="toc"></div>
  </div>
  {% endif %}

  <footer class="post-footer">
    {% if page.tags and page.tags.length > 0 %}
    <div class="post-tags">
      {% for tag in page.tags.toArray() %}
      <a href="{{ url_for(tag.path) }}" class="tag">{{ tag.name }}</a>
      {% endfor %}
    </div>
    {% endif %}
  </footer>
</article>
